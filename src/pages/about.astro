---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us" description="ZAULUX — From 'Zhuang' to ZAULUX, Illuminating the Path of Intelligent Manufacturing.">
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="hero-top">
        <span class="tag tag-primary hero-brand-tag">Brand Story</span>
        <div class="about-logo">
          <img src="/images/menu-logo.png" alt="ZAULUX" />
        </div>
      </div>
      <h1>About ZAULUX</h1>
      <p class="hero-slogan">Lighting the Way to Smart Welding</p>
    </div>
  </section>

  <!-- ===== 一、品牌起源 ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">From "Zhuang" to ZAULUX</h2>
      <p class="section-sub">Rooted in Heritage, Connected to the World</p>
      <div class="origin-block">
        <p>
          Our brand identity is inspired by the Chinese character <strong>"Zhuang" (庄)</strong>.
          Historically, it signifies a central hub where six roads meet —
          a symbol of connectivity and convergence. It also evokes the idiom
          <em>"Kangzhuang Dadao"</em>, representing a broad, bright, and promising path forward.
          This is our cultural foundation and our promise to global trade:
          <strong>to be the intelligent hub connecting the world and to forge a path of enduring innovation.</strong>
        </p>
        <p>
          To share this vision globally, we created the name <strong>ZAULUX</strong>.
          Welding is the art of fire and light; Intelligence is the fusion of data and precision.
          At ZAULUX, we combine traditional welding craftsmanship with cutting-edge photonic technology.
          Every precise weld and every stable arc is a manifestation of intelligent light.
        </p>
        <blockquote>
          <p>"ZAULUX — More than equipment. We are the light guiding you into the future of smart manufacturing."</p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ===== 二、企业简介 + 统计 ===== -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Company Profile</h2>
      <p class="section-sub">20+ Years of Welding Equipment Manufacturing, Serving 50+ Countries Worldwide</p>

      <div class="about-split">
        <div class="about-text">
          <p>
            ZAULUX is a <strong>professional welding equipment manufacturer</strong> integrating
            R&D, manufacturing, sales, and service. With over 20 years of industry experience,
            our main products include welding positioners, turning rolls, boom & column manipulators,
            H-beam production lines, robotic welding systems, and specialized automation equipment.
          </p>
          <p>
            Our equipment serves industries including petrochemical, wind power, shipbuilding,
            mining machinery, steel structure construction, and aerospace — exported to
            50+ countries with over 1,000 systems installed worldwide.
          </p>
          <p>
            We are driven by <strong>customer-focused innovation</strong>, delivering end-to-end
            solutions from scheme design and equipment manufacturing to installation,
            commissioning, and after-sales service.
          </p>
          <ul class="commit-list">
            <li><span>✓</span> CE Certified, ISO Quality Management System</li>
            <li><span>✓</span> Custom Engineering: voltage, height, explosion-proof, roller materials</li>
            <li><span>✓</span> Remote Commissioning + Global After-Sales Support</li>
            <li><span>✓</span> Pre-Shipment Video Inspection — see it run before it ships</li>
          </ul>
        </div>
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat-num">20+</span>
            <span class="about-stat-label">Years of<br />Experience</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">50+</span>
            <span class="about-stat-label">Export<br />Countries</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">1000+</span>
            <span class="about-stat-label">Installed<br />Systems</span>
          </div>
          <div class="about-stat">
            <span class="about-stat-num">64+</span>
            <span class="about-stat-label">Product<br />Models</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 三、企业文化 ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Corporate Culture</h2>
      <p class="section-sub">United by culture, driven by purpose</p>

      <div class="culture-grid">
        <div class="culture-card">
          <div class="culture-icon">🔥</div>
          <h3>Our Spirit</h3>
          <p>Precision in every weld, innovation for the future — where craftsmanship meets cutting-edge technology.</p>
        </div>
        <div class="culture-card">
          <div class="culture-icon">🤝</div>
          <h3>Core Values</h3>
          <p>Integrity, Customer First, Quality Excellence, Innovation Driven — the ZAULUX promise to every partner.</p>
        </div>
        <div class="culture-card">
          <div class="culture-icon">🌍</div>
          <h3>Business Philosophy</h3>
          <p>Rooted in China, serving the world — the intelligent hub where global manufacturing needs converge.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 四、愿景使命 ===== -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Vision & Mission</h2>
      <p class="section-sub">Lighting the Way to Smart Welding</p>

      <div class="vm-grid">
        <div class="vm-card">
          <h3>🎯 Our Vision</h3>
          <p>To become a global benchmark in intelligent welding equipment — making ZAULUX synonymous with smart manufacturing.</p>
        </div>
        <div class="vm-card">
          <h3>🚀 Our Mission</h3>
          <p>Precision Welding, Powered by Light — delivering reliable, intelligent, and efficient welding solutions to global manufacturers.</p>
        </div>
        <div class="vm-card">
          <h3>💡 Brand Promise</h3>
          <p>Smart Arcs, Bright Future.<br/>ZAULUX: Lighting the Way to Smart Welding.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 五、服务保障 ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What We Offer</h2>
      <p class="section-sub">End-to-end service — from design to after-sales</p>

      <div class="offer-grid">
        <div class="offer-item">
          <h3>📐 Custom Engineering</h3>
          <p>Non-standard voltage (110V–690V), custom dimensions, explosion-proof variants, special roller materials — built to your specs.</p>
        </div>
        <div class="offer-item">
          <h3>📋 Technical Documentation</h3>
          <p>CAD drawings, installation manuals, wiring diagrams — available in English, Spanish, Russian, and Arabic.</p>
        </div>
        <div class="offer-item">
          <h3>🎥 Remote Commissioning</h3>
          <p>Live video-guided installation and operator training — no waiting for on-site engineers to arrive.</p>
        </div>
        <div class="offer-item">
          <h3>🔧 Spare Parts Supply</h3>
          <p>Motors, reducers, VFDs, rollers, and control boards — stocked inventory, shipped within 48 hours.</p>
        </div>
        <div class="offer-item">
          <h3>🏭 Factory Acceptance Test</h3>
          <p>Pre-shipment video inspection — watch your machine run before it leaves our factory.</p>
        </div>
        <div class="offer-item">
          <h3>🛠️ After-Sales Support</h3>
          <p>12-month warranty with extended plans available. Remote troubleshooting + on-site service for major installations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <h2>Smart Arcs, Bright Future</h2>
      <p>Let ZAULUX light the way to your next intelligent welding solution.</p>
      <a href="/contact/" class="btn btn-accent btn-lg">Contact Us</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--bg-section-alt);
    padding: var(--space-3xl) 0;
    text-align: center;
  }
  .page-hero h1 { font-size: 2.25rem; }
  .page-hero p { color: var(--text-secondary); margin-top: var(--space-sm); }
  .hero-brand-tag { margin-bottom: var(--space-md); }

  .about-logo {
    display: inline-block;
    vertical-align: middle;
  }
  .about-logo img {
    height: 50px;
    width: auto;
  }
  .hero-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }
  .hero-slogan {
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: var(--text-heading) !important;
    font-style: italic;
    margin-top: var(--space-sm) !important;
  }

  .section-title { text-align: center; margin-bottom: var(--space-sm); }
  .section-sub { text-align: center; color: var(--text-secondary); max-width: 640px; margin: 0 auto var(--space-2xl); }

  .origin-block {
    max-width: 800px;
    margin: 0 auto;
  }
  .origin-block p {
    color: var(--text-body);
    line-height: 1.85;
    margin-bottom: var(--space-md);
    font-size: 1rem;
  }
  .origin-block blockquote {
    margin-top: var(--space-lg);
    border-left: 3px solid var(--color-primary);
    background: var(--bg-highlight);
    padding: var(--space-lg) var(--space-xl);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .about-split {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .about-text p { color: var(--text-body); margin-bottom: var(--space-md); line-height: 1.8; }
  .commit-list {
    list-style: none;
    margin-top: var(--space-md);
  }
  .commit-list li {
    padding: 5px 0;
    font-size: var(--font-size-small);
    color: var(--text-body);
  }
  .commit-list li span { color: var(--color-success); font-weight: 700; margin-right: 8px; }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  .about-stat {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
  }
  .about-stat-num {
    display: block;
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .about-stat-label {
    display: block;
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    margin-top: 4px;
    line-height: 1.4;
  }

  .culture-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 960px;
    margin: 0 auto;
  }
  .culture-card {
    text-align: center;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    transition: box-shadow var(--transition-base);
  }
  .culture-card:hover { box-shadow: var(--shadow-md); }
  .culture-icon { font-size: 3rem; margin-bottom: var(--space-sm); }
  .culture-card h3 { margin-bottom: var(--space-sm); font-size: 1.0625rem; color: var(--text-heading); }
  .culture-card p { color: var(--text-secondary); font-size: var(--font-size-small); line-height: 1.65; }

  .vm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 960px;
    margin: 0 auto;
  }
  .vm-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }
  .vm-card h3 { margin-bottom: var(--space-sm); font-size: 1.0625rem; color: var(--text-heading); }
  .vm-card p { color: var(--text-secondary); font-size: var(--font-size-small); line-height: 1.65; }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .offer-item {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }
  .offer-item h3 { margin-bottom: var(--space-sm); font-size: 1rem; }
  .offer-item p { color: var(--text-secondary); font-size: var(--font-size-small); line-height: 1.6; }

  .cta-section { text-align: center; }
  .cta-inner {
    background: var(--bg-section-alt);
    border-radius: var(--radius-lg);
    padding: var(--space-3xl) var(--space-lg);
  }
  .cta-inner h2 { margin-bottom: var(--space-sm); }
  .cta-inner p { color: var(--text-secondary); margin-bottom: var(--space-xl); }
  .btn-lg { padding: 14px 36px; font-size: 1.0625rem; }

  @media (max-width: 768px) {
    .about-split { grid-template-columns: 1fr; }
    .culture-grid { grid-template-columns: 1fr; }
    .vm-grid { grid-template-columns: 1fr; }
    .offer-grid { grid-template-columns: 1fr; }
    .about-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
