---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Product Gallery">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Product Gallery</h1>
      <p class="page-sub">Explore our welding equipment across all categories.</p>

      <div class="filter-bar" id="filterBar"></div>
      <div id="galleryContainer"><p class="loading-text">Loading gallery...</p></div>
    </div>
  </section>
</Layout>

<script>
  fetch('/gallery-data.json')
    .then(r => r.json())
    .then(data => {
      // Build filter tabs
      let filterHtml = '<button class="tag tag-primary filter-btn active" data-idx="all">All</button>';
      data.categories.forEach((cat, i) => {
        filterHtml += '<button class="tag tag-subtle filter-btn" data-idx="' + i + '">' + cat.category + '</button>';
      });
      document.getElementById('filterBar').innerHTML = filterHtml;

      function render(filterIdx) {
        let html = '';
        if (filterIdx === 'all') {
          // Show all images in a continuous grid, 4 per row
          html += '<div class="gallery-row">';
          data.all.forEach((img, i) => {
            html += '<div class="gallery-item"><img src="' + img + '" alt="" loading="lazy" /></div>';
          });
          html += '</div>';
        } else {
          const cat = data.categories[filterIdx];
          html += '<h2 class="cat-title">' + cat.category + ' <span class="cat-count">' + (cat.rows.reduce((s,r) => s + r.length, 0)) + ' photos</span></h2>';
          cat.rows.forEach(row => {
            html += '<div class="gallery-row">';
            row.forEach(img => {
              html += '<div class="gallery-item"><img src="' + img + '" alt="" loading="lazy" /></div>';
            });
            html += '</div>';
          });
        }
        document.getElementById('galleryContainer').innerHTML = html || '<p>No images.</p>';
      }

      render('all');

      document.querySelectorAll('#filterBar .filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#filterBar .filter-btn').forEach(b => { b.classList.remove('active'); b.classList.add('tag-subtle'); });
          btn.classList.add('active'); btn.classList.remove('tag-subtle');
          render(btn.dataset.idx === 'all' ? 'all' : parseInt(btn.dataset.idx));
        });
      });
    });
</script>

<style>
  .page-title { text-align: center; font-size: 2.25rem; }
  .page-sub { text-align: center; color: var(--text-secondary); margin-bottom: var(--space-xl); }
  .loading-text { text-align: center; color: var(--text-secondary); }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: var(--space-2xl); }
  .filter-btn { background: var(--bg-card); color: var(--text-body); cursor: pointer; transition: all var(--transition-fast); border: 1px solid var(--border-card); font-family: inherit; font-size: var(--font-size-small); font-weight: 600; }
  .filter-btn:hover { background: var(--color-primary); color: var(--color-soft-white); }
  .filter-btn.active { background: var(--color-primary); color: var(--color-soft-white); }

  .cat-title { font-size: 1.25rem; color: var(--text-heading); margin-bottom: var(--space-lg); padding-bottom: var(--space-sm); border-bottom: 2px solid var(--border-default); }
  .cat-count { font-size: var(--font-size-small); color: var(--text-secondary); font-weight: 400; margin-left: 8px; }

  .gallery-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 12px; }
  .gallery-item { aspect-ratio: 4/3; border-radius: var(--radius-md); overflow: hidden; background: var(--bg-card); border: 1px solid var(--border-light); }
  .gallery-item img { width: 100%; height: 100%; object-fit: contain; padding: 8px; background: var(--bg-page); display: block; transition: transform var(--transition-base); }
  .gallery-item:hover img { transform: scale(1.03); }

  @media (max-width: 768px) { .gallery-row { grid-template-columns: repeat(2, 1fr); } }
</style>
