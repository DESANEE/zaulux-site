---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Applications by Industry">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Applications by Industry</h1>
      <p class="page-sub">Select an industry to explore related welding equipment.</p>

      <div class="filter-bar" id="appFilter"></div>
      <div id="appContent"><p class="loading-text">Loading...</p></div>
    </div>
  </section>
</Layout>

<script>
  Promise.all([
    fetch('/applications.json').then(r => r.json()),
    fetch('/products/search-data.json').then(r => r.json())
  ]).then(([apps, products]) => {
    const productMap = {};
    products.forEach(p => { productMap[p.slug] = p.title; });

    // Build filter tabs
    const industries = Object.keys(apps);
    let filterHtml = '<button class="tag tag-primary filter-btn active" data-idx="all">All Industries</button>';
    industries.forEach((ind, i) => {
      filterHtml += '<button class="tag tag-subtle filter-btn" data-idx="' + i + '">' + ind + ' <small>(' + apps[ind].length + ')</small></button>';
    });
    document.getElementById('appFilter').innerHTML = filterHtml;

    function render(filterIdx) {
      let html = '';
      const list = filterIdx === 'all' ? industries.map(i => ({industry: i, slugs: apps[i]})) : [{industry: industries[filterIdx], slugs: apps[industries[filterIdx]]}];

      list.forEach(item => {
        html += '<div class="app-section">';
        html += '<h2 class="app-title">' + item.industry + ' <span class="app-count">' + item.slugs.length + ' products</span></h2>';
        html += '<div class="product-card-grid">';
        item.slugs.forEach(slug => {
          const title = productMap[slug] || slug;
          html += '<a href="/products/' + slug + '/" class="product-mini-card">';
          html += '<strong>' + title + '</strong>';
          html += '<span class="arrow">→</span>';
          html += '</a>';
        });
        html += '</div>';
        html += '</div>';
      });
      document.getElementById('appContent').innerHTML = html || '<p>No products found.</p>';
    }

    render('all');

    document.querySelectorAll('#appFilter .filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#appFilter .filter-btn').forEach(b => { b.classList.remove('active'); b.classList.add('tag-subtle'); });
        btn.classList.add('active'); btn.classList.remove('tag-subtle');
        render(btn.dataset.idx === 'all' ? 'all' : parseInt(btn.dataset.idx));
      });
    });
  });
</script>

<style is:global>
  .page-title { text-align: center; font-size: 2.25rem; }
  .page-sub { text-align: center; color: var(--text-secondary); margin-bottom: var(--space-xl); }
  .loading-text { text-align: center; color: var(--text-secondary); }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: var(--space-2xl); }
  .filter-btn { background: var(--bg-card); color: var(--text-body); cursor: pointer; transition: all var(--transition-fast); border: 1px solid var(--border-card); font-family: inherit; font-size: var(--font-size-small); font-weight: 600; }
  .filter-btn small { opacity: 0.6; font-weight: 400; }
  .filter-btn:hover { background: var(--color-primary); color: var(--color-soft-white); }
  .filter-btn.active { background: var(--color-primary); color: var(--color-soft-white); }

  .app-section { margin-bottom: var(--space-2xl); }
  .app-title { font-size: 1.25rem; color: var(--text-heading); margin-bottom: var(--space-lg); padding-bottom: var(--space-sm); border-bottom: 2px solid var(--border-default); }
  .app-count { font-size: var(--font-size-small); color: var(--text-secondary); font-weight: 400; margin-left: 8px; }

  .product-card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }
  .product-mini-card {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border-light);
    border-radius: var(--radius-md); text-decoration: none; color: var(--text-body);
    transition: all var(--transition-fast); font-size: var(--font-size-small);
  }
  .product-mini-card:hover { border-color: var(--color-primary); background: var(--bg-section-alt); }
  .product-mini-card strong { font-weight: 600; color: var(--text-heading); flex: 1; padding-right: 8px; }
  .product-mini-card .arrow { color: var(--color-primary); font-size: 1rem; }

  @media (max-width: 768px) { .product-card-grid { grid-template-columns: 1fr; } }
</style>
