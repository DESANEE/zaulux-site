---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/product-list';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug }, props: p }));
}

const product = Astro.props;
const { title, category, description, images } = product;
---

<Layout title={title} description={description}>
  <section class="section">
    <div class="container">
      <a href="/products/" class="back-link">← Back to Products</a>

      <div class="product-layout">
        <div class="product-hero-img">
          {images.length > 0 ? (
            <img src={images[0].url} alt={images[0].alt} class="product-main-img" />
          ) : (
            <span class="no-img">No Image</span>
          )}
        </div>

        <div class="product-detail">
          <span class="tag tag-primary">{category}</span>
          <h1>{title}</h1>
          {description && <p class="lead">{description}</p>}
          <a href="/contact/" class="btn btn-accent">Request Quote</a>
        </div>
      </div>

      {description && (
        <div class="section-inner">
          <h2>Overview</h2>
          <p class="overview-text">{description}</p>
        </div>
      )}

      {images.length > 1 && (
        <div class="section-inner">
          <h2>Product Gallery</h2>
          <div class="image-gallery">
            {images.map((img: any, i: number) => (
              <figure>
                <img src={img.url} alt={img.alt} loading="lazy" />
                <figcaption>{img.alt}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section section-alt cta-bottom">
    <div class="container cta-inner">
      <h2>Interested in the {title}?</h2>
      <p>Contact our engineering team for a customized quotation and delivery timeline.</p>
      <a href="/contact/" class="btn btn-accent btn-lg">Get a Quote</a>
    </div>
  </section>
</Layout>

<style>
  .back-link { display: inline-block; margin-bottom: var(--space-xl); color: var(--text-secondary); font-size: var(--font-size-small); text-decoration: none; }
  .back-link:hover { color: var(--text-link-hover); }

  .product-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3xl); align-items: start; }
  .product-hero-img { background: var(--bg-section-alt); border-radius: var(--radius-lg); min-height: 300px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .product-main-img { width: 100%; height: 100%; object-fit: cover; min-height: 300px; }
  .no-img { font-size: 3rem; color: var(--text-secondary); }
  .product-detail h1 { font-size: 2rem; margin: var(--space-md) 0; }
  .product-detail .tag { margin-bottom: var(--space-sm); }
  .lead { color: var(--text-secondary); font-size: 1.0625rem; margin: var(--space-md) 0 var(--space-xl); line-height: 1.7; }

  .section-inner { margin-top: var(--space-3xl); }
  .section-inner h2 { margin-bottom: var(--space-lg); }
  .overview-text { color: var(--text-body); line-height: 1.8; max-width: 800px; margin: 0 auto; }

  .image-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-md); }
  .image-gallery figure { margin: 0; border-radius: var(--radius-md); overflow: hidden; background: var(--bg-card); border: 1px solid var(--border-light); }
  .image-gallery img { width: 100%; height: 180px; object-fit: cover; }
  .image-gallery figcaption { padding: 8px 12px; font-size: var(--font-size-small); color: var(--text-secondary); text-align: center; }

  .cta-bottom { text-align: center; }
  .cta-inner { padding: var(--space-3xl) var(--space-lg); border-radius: var(--radius-lg); }

  @media (max-width: 768px) { .product-layout { grid-template-columns: 1fr; } .image-gallery { grid-template-columns: repeat(2, 1fr); } }
</style>
