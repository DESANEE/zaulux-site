---
import Layout from '../../layouts/Layout.astro';

// Dynamic import — reads all MDX product files
const allProducts = import.meta.glob('../../content/products/*.mdx', { eager: true });

const products = Object.entries(allProducts).map(([path, mod]: [string, any]) => {
  const slug = path.split('/').pop()?.replace('.mdx', '') || '';
  const fm = mod.frontmatter || {};
  return {
    slug,
    title: fm.title || slug.replace(/-/g, ' '),
    category: fm.category || 'Uncategorised',
    desc: (fm.description || '').slice(0, 120),
    images: fm.images || [],
  };
});

const categories = [...new Set(products.map(p => p.category))].sort();
---
---

<Layout title="Products">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Products</h1>
      <p class="page-sub">Complete range of welding equipment and automation solutions.</p>

      <!-- 分类筛选 -->
      <div class="filter-bar">
        <a href="/products/" class="tag tag-primary filter-active">All</a>
        {categories.map(cat => (
          <a href={`/products/?cat=${cat}`} class="tag tag-subtle filter-tag">{cat}</a>
        ))}
      </div>

      <!-- 产品列表 -->
      <div class="product-list">
        {products.map(product => (
          <a href={`/products/${product.slug}/`} class="product-card">
            <div class="product-img-placeholder">
              {product.images.length > 0 ? (
                <img src={product.images[0].url} alt={product.images[0].alt} loading="lazy" style="width:100%;height:100%;object-fit:cover" />
              ) : (
                product.category === 'positioner' ? '🔄' :
                product.category === 'turning rolls' ? '⚙️' :
                product.category === 'boom&column' ? '🏗️' :
                product.category === 'h beam' ? '📐' :
                product.category === 'robot' ? '🤖' :
                product.category === 'beveling' ? '🔧' :
                product.category === 'automation' ? '⚡' :
                product.category === 'hydraulic' ? '💧' : '🔩'
              )}
            </div>
            <div class="product-info">
              <span class="tag tag-subtle">{product.category}</span>
              <h3>{product.title}</h3>
              <p class="product-desc">{product.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-title {
    text-align: center;
    font-size: 2.25rem;
  }
  .page-sub {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }
  .filter-tag {
    background: var(--bg-card);
    color: var(--text-body);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-tag:hover {
    background: var(--color-primary);
    color: var(--color-soft-white);
  }
  .filter-active {
    background: var(--color-primary);
    color: var(--color-soft-white);
    text-decoration: none;
  }

  .product-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-card);
    color: inherit;
  }
  .product-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    color: inherit;
  }
  .product-img-placeholder {
    background: var(--bg-section-alt);
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }
  .product-info {
    padding: var(--space-md) var(--space-lg) var(--space-lg);
  }
  .product-info h3 {
    margin: var(--space-sm) 0;
    font-size: 1rem;
  }
  .product-desc {
    color: var(--text-secondary);
    font-size: var(--font-size-small);
    line-height: 1.5;
  }
</style>
