---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/product-list';

const categories = [...new Set(products.map(p => p.category))].sort();
---

<Layout title="Welding Equipment &amp; Automation Products | Positioners, Rotators, Manipulators - ZAULUX">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Products</h1>
      <p class="page-sub">Complete range of welding equipment and automation solutions.</p>

      <div class="filter-bar">
        <button class="tag tag-primary filter-btn active" data-cat="all">All</button>
        {categories.map(cat => (
          <button class="tag tag-subtle filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="product-list">
        {products.map(product => (
          <a href={`/products/${product.slug}/`} class="product-card">
            <div class="product-img-placeholder">
              {product.images.length > 0 ? (
                <img src={product.images[0].url} alt={product.images[0].alt} loading="lazy" />
              ) : (
                <span class="no-img-icon">🔩</span>
              )}
            </div>
            <div class="product-info">
              <span class="tag tag-subtle">{product.category}</span>
              <h3>{product.title}</h3>
              <p class="product-desc">{product.description.slice(0, 120)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.product-card');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => { b.classList.remove('active'); b.classList.add('tag-subtle'); });
      btn.classList.add('active'); btn.classList.remove('tag-subtle');
      const cat = btn.dataset.cat;
      items.forEach(item => {
        const cardCat = item.querySelector('.tag-subtle')?.textContent;
        item.style.display = (cat === 'all' || cardCat === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .page-title { text-align: center; font-size: 2.25rem; }
  .page-sub { text-align: center; color: var(--text-secondary); margin-bottom: var(--space-xl); }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: var(--space-2xl); }
  .filter-btn { background: var(--bg-card); color: var(--text-body); cursor: pointer; transition: all var(--transition-fast); border: 1px solid var(--border-card); font-family: inherit; font-size: var(--font-size-small); font-weight: 600; }
  .filter-btn:hover { background: var(--color-primary); color: var(--color-soft-white); }
  .filter-btn.active { background: var(--color-primary); color: var(--color-soft-white); }

  .product-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-lg); }

  .product-card { background: var(--bg-card); border: 1px solid var(--border-card); border-radius: var(--radius-lg); overflow: hidden; text-decoration: none; transition: all var(--transition-base); box-shadow: var(--shadow-card); color: inherit; }
  .product-card:hover { box-shadow: var(--shadow-card-hover); transform: translateY(-2px); color: inherit; }
  .product-img-placeholder { background: var(--bg-section-alt); height: 160px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .product-img-placeholder img { width: 100%; height: 100%; object-fit: contain; }
  .no-img-icon { font-size: 2.5rem; }
  .product-info { padding: var(--space-md) var(--space-lg) var(--space-lg); }
  .product-info h3 { margin: var(--space-sm) 0; font-size: 1rem; }
  .product-desc { color: var(--text-secondary); font-size: var(--font-size-small); line-height: 1.5; }
</style>
